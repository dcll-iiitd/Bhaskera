# =============================================================================
# Bhaskera — Param2-17B MoE fine-tuning config
#
# Auto-detected (no hardcoding needed):
#   - Decoder layer class       ← introspect.py finds it
#   - Expert modules for FSDP   ← introspect.py finds them
#   - LoRA target modules       ← introspect.py discovers all nn.Linear in decoder
#   - Model dtype (bf16/fp16)   ← read from model checkpoint
#   - Auxiliary loss             ← detected from model config
#   - Router/gate freezing      ← detected from module tree
# =============================================================================

model:
  name: "bharatgenai/Param2-17B-A2.4B-Thinking"
  dtype: "auto"                    # reads native dtype from checkpoint
  attn_impl: null                  # flash_attention_2 if available
  trust_remote_code: true          # required for Param2

data:
  name: "ultrachat"
  seq_len: 4096                    # Param2 native context length
  num_workers: 4

lora:
  enabled: true
  r: 16
  alpha: 32
  dropout: 0.05
  target_modules: ["auto"]         # auto-discovers q_proj, k_proj, v_proj, etc.
  include_experts: false           # set true to also LoRA expert FFN layers
  freeze_router: true              # keep routing stable during fine-tuning
  modules_to_save: []              # e.g. ["lm_head"] to fully train the head

moe:
  aux_loss_weight: 0.01            # weight for load-balancing auxiliary loss
  router_z_loss_weight: 0.001      # router z-loss for stability
  freeze_router: true
  log_expert_utilization: true     # monitor expert collapse
  log_every_n_steps: 10

training:
  batch_size: 1                    # small for 17B MoE
  grad_accum: 8
  lr: 1e-4                         # conservative for fine-tuning
  weight_decay: 0.01
  max_steps: 2000
  num_epochs: 1
  warmup_steps: 200
  max_grad_norm: 1.0

  distributed:
    strategy: "fsdp"

    fsdp:
      sharding_strategy: "FULL_SHARD"
      transformer_layer_cls: []          # empty = auto-detect (recommended)
      param_dtype: "auto"                # reads from model
      reduce_dtype: "auto"               # auto = float32 for MoE (safer)
      buffer_dtype: "auto"
      activation_checkpointing: true
      cpu_offload: false
      shard_experts_individually: true   # per-expert FSDP — critical for MoE

    ddp:
      find_unused_parameters: false      # auto-forced true for MoE
      gradient_as_bucket_view: true
      broadcast_buffers: false

checkpoint:
  enabled: true
  save_dir: "./checkpoints/param2"
  save_interval: 1
  keep_last_n: 2

logging:
  tracker: "wandb"
  project: "bhaskera-param2"
  run_name: "param2-17b-lora"
  log_gpu_every_n_steps: 10
