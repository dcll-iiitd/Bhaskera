{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Bhaskera LLM fine-tuning observability — losses, throughput, GPU/CPU telemetry, NVLink/PCIe, CUDA allocator, MFU.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "title": "Training",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "title": "Loss",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "bhaskera_loss{run_name=~\"$run_name\"}",
          "legendFormat": "loss",
          "refId": "A"
        },
        {
          "expr": "bhaskera_loss_running_avg{run_name=~\"$run_name\"}",
          "legendFormat": "loss EMA",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Loss spike ratio (loss / EMA)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "targets": [
        {
          "expr": "bhaskera_loss_spike_ratio{run_name=~\"$run_name\"}",
          "legendFormat": "spike",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1.5},
              {"color": "red", "value": 3}
            ]
          }
        }
      }
    },
    {
      "title": "Gradient norm",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "targets": [
        {
          "expr": "bhaskera_grad_norm{run_name=~\"$run_name\"}",
          "legendFormat": "grad_norm",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Learning rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 9},
      "targets": [
        {
          "expr": "bhaskera_lr{run_name=~\"$run_name\"}",
          "legendFormat": "lr",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tokens/sec (global)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 9},
      "targets": [
        {
          "expr": "bhaskera_throughput_tokens_per_sec{run_name=~\"$run_name\"}",
          "legendFormat": "tokens/s",
          "refId": "A"
        },
        {
          "expr": "bhaskera_throughput_tokens_per_sec_per_gpu{run_name=~\"$run_name\"}",
          "legendFormat": "tokens/s/GPU",
          "refId": "B"
        }
      ]
    },
    {
      "title": "MFU %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 9},
      "targets": [
        {
          "expr": "bhaskera_throughput_mfu_pct{run_name=~\"$run_name\"}",
          "legendFormat": "MFU",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "type": "row",
      "title": "GPU",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "collapsed": false
    },
    {
      "title": "GPU utilisation %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "bhaskera_gpu_util_pct{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "title": "GPU memory used %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "bhaskera_gpu_mem_used_pct{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "title": "GPU temperature (°C)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "bhaskera_gpu_temp_c{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GPU power (W)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "targets": [
        {
          "expr": "bhaskera_gpu_power_w{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GPU clock (SM, MHz)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "targets": [
        {
          "expr": "bhaskera_gpu_clock_sm_mhz{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GPU throttle (any reason)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "max(bhaskera_gpu_throttle_hw_thermal_slowdown{run_name=~\"$run_name\"} or bhaskera_gpu_throttle_sw_thermal_slowdown{run_name=~\"$run_name\"} or bhaskera_gpu_throttle_hw_power_brake_slowdown{run_name=~\"$run_name\"} or bhaskera_gpu_throttle_sw_power_cap{run_name=~\"$run_name\"}) by (rank, gpu_id)",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "ECC errors (volatile)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "bhaskera_gpu_ecc_dbe_volatile{run_name=~\"$run_name\"}",
          "legendFormat": "DBE rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        },
        {
          "expr": "bhaskera_gpu_ecc_sbe_volatile{run_name=~\"$run_name\"}",
          "legendFormat": "SBE rank {{rank}} / gpu {{gpu_id}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Interconnect",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
      "collapsed": false
    },
    {
      "title": "PCIe Tx (KB/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 39},
      "targets": [
        {
          "expr": "bhaskera_gpu_pcie_tx_kbs{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "PCIe Rx (KB/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 39},
      "targets": [
        {
          "expr": "bhaskera_gpu_pcie_rx_kbs{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "NVLink Tx (MiB/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 39},
      "targets": [
        {
          "expr": "bhaskera_gpu_nvlink_tx_mibs{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "NVLink Rx (MiB/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 39},
      "targets": [
        {
          "expr": "bhaskera_gpu_nvlink_rx_mibs{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}} / gpu {{gpu_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "CUDA allocator (PyTorch)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45},
      "collapsed": false
    },
    {
      "title": "CUDA allocated (MiB)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 46},
      "targets": [
        {
          "expr": "bhaskera_cuda_allocated_mib{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CUDA reserved (MiB)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 46},
      "targets": [
        {
          "expr": "bhaskera_cuda_reserved_mib{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Host (CPU / IO)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 53},
      "collapsed": false
    },
    {
      "title": "System CPU %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 54},
      "targets": [
        {
          "expr": "bhaskera_sys_cpu_pct{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "title": "System memory used %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 54},
      "targets": [
        {
          "expr": "bhaskera_sys_mem_used_pct{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "title": "Process RSS (MiB)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 54},
      "targets": [
        {
          "expr": "bhaskera_proc_rss_mib{run_name=~\"$run_name\"}",
          "legendFormat": "rank {{rank}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Disk read/write (MiB/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 60},
      "targets": [
        {
          "expr": "bhaskera_sys_disk_read_mibs{run_name=~\"$run_name\"}",
          "legendFormat": "read rank {{rank}}",
          "refId": "A"
        },
        {
          "expr": "bhaskera_sys_disk_write_mibs{run_name=~\"$run_name\"}",
          "legendFormat": "write rank {{rank}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Network recv/send (MiB/s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 60},
      "targets": [
        {
          "expr": "bhaskera_sys_net_recv_mibs{run_name=~\"$run_name\"}",
          "legendFormat": "recv rank {{rank}}",
          "refId": "A"
        },
        {
          "expr": "bhaskera_sys_net_sent_mibs{run_name=~\"$run_name\"}",
          "legendFormat": "send rank {{rank}}",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["bhaskera", "llm", "fine-tuning", "ray"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0
      },
      {
        "name": "run_name",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(bhaskera_loss, run_name)",
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "refresh": "15s",
  "title": "Bhaskera — LLM Fine-tuning",
  "uid": "bhaskera-finetuning",
  "version": 1
}
